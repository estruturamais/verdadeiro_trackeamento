{
  "site_id": "curso-marketing-digital",
  "debug": false,
  "platforms": {
    "ga4": {
      "measurement_id": "G-ABC123DEF4"
    },
    "meta": {
      "pixel_id": "111111111111111",
      "pixel_id_purchase": "222222222222222",
      "purchase_trigger_event": "lead"
    },
    "tiktok": {
      "pixel_id": "CP1234567890ABCDEF",
      "access_token": "{EXCECAO: TikTok nao faz fallback para env — incluir o access_token aqui, nao como wrangler secret}"
    },
    "google_ads": {
      "conversion_id": "AW-123456789",
      "channel": "server",
      "conversion_label_contact": "AbCdEf123",
      "conversion_label_lead": "GhIjKl456",
      "conversion_label_purchase": "MnOpQr789"
    }
  },
  "gateways": ["hotmart", "kiwify"],
  "gateways_config": {
    "hotmart": {
      "domains": ["hotmart.com", "pay.hotmart.com"],
      "caminho": "sck",
      "indexador": "xcod",
      "user_params": { "email": "email", "phone": "phonenumber", "name": "name" }
    }
  },
  "triggers": {
    "lead": {
      "type": "form_submit",
      "selectors": { "elementor": true, "cf7": true, "generic": true }
    },
    "contact": {
      "type": "link_click",
      "match": "wa.me|api.whatsapp"
    },
    "initiate_checkout": {
      "type": "link_click",
      "match": "pay"
    }
  },
  "custom_data": {
    "page_type": {
      "conditions": [
        { "if": "document.title.includes('vendas')", "value": "vendas" }
      ],
      "fallback": "outras"
    }
  },
  "cookies": {
    "user": "marca_user",
    "email": "marca_email",
    "phone": "marca_phone",
    "name": "marca_name"
  },
  "logging": {
    "enabled": true,
    "retention_days": 30,
    "log_bearer_token": "{token-secreto-opcional}"
  }
}
