{
  "name": "verdadeiro-trackeamento",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "cp src/web.js src/web-template.txt",
    "dev": "cp src/web.js src/web-template.txt && wrangler dev",
    "deploy": "cp src/web.js src/web-template.txt && wrangler deploy",
    "db:create": "wrangler d1 create tracking_db",
    "db:migrate": "wrangler d1 execute tracking_db --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute tracking_db --local --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.78.0"
  }
}
